        <!-- ============================================================ -->
        <!-- SECURITY ANNOTATIONS -->
        <!-- ============================================================ -->
        <mxCell id="sec_note_1" value="&#x1f6e1;&#xfe0f; Security Layers:&#xa;1. WAF (CRS + SQLi + Bad Inputs + Rate Limit)&#xa;2. CloudFront → ALB shared secret header&#xa;3. ALB SG: CloudFront prefix-list only&#xa;4. Network Firewall: domain allowlist&#xa;5. Private subnets: no public IPs&#xa;6. VPC Endpoints: traffic stays on AWS backbone&#xa;7. EFS: encrypted at rest, NFS from private only&#xa;8. S3: public access blocked, OAC" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#DD344C;fillColor=#FFF2EF;fontSize=10;fontColor=#232F3E;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="1320" width="320" height="150" as="geometry" />
        </mxCell>

        <mxCell id="sec_note_2" value="&#x1f4ca; Monitoring &amp; Alerts:&#xa;• ECS: CPU &gt; 80%, Memory &gt; 80%, RunningCount &lt; 1&#xa;• ALB: 5xx &gt; 10, Latency &gt; 5s, Unhealthy hosts&#xa;• DynamoDB: Throttled requests&#xa;• Lambda: Errors &gt; 3, DLQ messages&#xa;• WAF: Blocked &gt; 100/5min&#xa;• VPC Flow Logs on both VPCs&#xa;All → SNS → Email" style="text;html=1;align=left;verticalAlign=top;resizable=1;points=[];autosize=0;strokeColor=#E7157B;fillColor=#FCE4EC;fontSize=10;fontColor=#232F3E;rounded=1;" vertex="1" parent="1">
